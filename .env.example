OZON_ACCOUNTS_FILE=/app/accounts.json

# How often collector polls Ozon (seconds)
POLL_INTERVAL_SECONDS=300

# How far back to look on first run (days)
INITIAL_LOOKBACK_DAYS=7

# Kafka / Redpanda
KAFKA_BOOTSTRAP=redpanda:9092
KAFKA_TOPIC_POSTINGS=ozon.postings
KAFKA_TOPIC_PRODUCTS=ozon.products

# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=ozon
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# MinIO (raw layer)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ozon-raw

# Anonymization salt (changes hash output for buyer identifiers)
ANONYMIZATION_SALT=change_me_to_random_string
